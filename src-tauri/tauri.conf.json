{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "opti-break",
  "version": "0.1.0",
  "identifier": "com.rafiaman.opti-break",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "opti-break",
        "url": "index.html?route=preferences",
        "width": 880,
        "height": 640,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "HealthcareFitness",
    "shortDescription": "20-20-20 eye care",
    "longDescription": "Reminds you to look 20 feet away for 20 seconds every 20 minutes.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
